data/**/*.parquet
data/**/*.csv
data/**/*.feather
*.onnx
*.pt
*.pth
*.ckpt

# --- Secrets / local config ---
.env
.env.*
*.key
secrets.*

# --- Local DB files ---
*.sqlite
*.db
*.dump

# --- Node / UI (ui/) ---
node_modules/
ui/dist/
ui/.vite/
*.tsbuildinfo
npm-debug.log*

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
